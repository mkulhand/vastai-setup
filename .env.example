GITHUB_TOKEN=github_pat_11AGZ...

# MinIO / S3-compatible — default AWS CLI config (only backend we use here).
S3_ENDPOINT=http://{ip}:{port}
AWS_ACCESS_KEY_ID={username}
AWS_SECRET_ACCESS_KEY={password}

# 1 = run MinIO S3 sync on container start (incremental). 0|false|no|off = skip.
MINIO_SYNC=1

WORKSPACE=/workspace


# docker compose (optional; defaults are in docker-compose.yaml)
COMFY_IMAGE=comfy-aio:cuda128
COMFY_PORT=18188
COMFY_CONTAINER_NAME=comfy-aio